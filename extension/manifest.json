{
  "manifest_version": 3,
  "name": "PhishGuard",
  "version": "1.0.0",
  "description": "AI-powered real-time phishing detection with visual similarity analysis",

  "permissions": [
    "activeTab",
    "tabs",
    "webNavigation",
    "storage",
    "alarms",
    "notifications",
    "declarativeNetRequest",
    "declarativeNetRequestFeedback"
  ],

  "host_permissions": [
    "http://localhost:7860/*",
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background/service-worker.js"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/default-16.png",
      "32": "icons/default-32.png",
      "48": "icons/default-48.png",
      "128": "icons/default-128.png"
    }
  },

  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content/content-script.js"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16": "icons/default-16.png",
    "32": "icons/default-32.png",
    "48": "icons/default-48.png",
    "128": "icons/default-128.png"
  },

  "declarative_net_request": {
    "rule_resources": []
  },

  "web_accessible_resources": [
    {
      "resources": [
        "lib/ort-wasm.wasm",
        "lib/ort-wasm-simd.wasm",
        "models/model.onnx",
        "blocked.html",
        "icons/*"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
